# OJ 平台环境变量配置示例
# 使用方式: 复制此文件为 .env，修改对应值

# ---- 数据库 ----
# Windows 集成身份验证 (推荐开发环境)
OJ_DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=OJPlatform;Trusted_Connection=yes

# SQL Server 身份验证 (如需)
# OJ_DATABASE_URL=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=OJPlatform;UID=sa;PWD=YourPassword

# ---- JWT ----
OJ_JWT_SECRET=change-me-to-a-random-secret-in-production

# ---- 评测 ----
# 评测调度器轮询间隔(秒)
# OJ_JUDGE_POLL_INTERVAL=1.0
